# Optional: leave empty to use this app's same-origin /api routes.
NEXT_PUBLIC_API_URL=

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenAI (required)
OPENAI_API_KEY=your-openai-api-key

# Tavily web search (recommended; some discovery paths degrade without it)
TAVILY_API_KEY=your-tavily-api-key

# Upstash Redis rate limiting (required for AI routes)
UPSTASH_REDIS_REST_URL=your-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# Optional: reserved for server-only administrative Supabase operations.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
